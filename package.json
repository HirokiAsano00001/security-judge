{
  "name": "security-judge",
  "version": "1.0.0",
  "description": "Claude Code MCP tool for autonomous security testing (Agentic Hacking)",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "security-judge": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "bin/"
  ],
  "scripts": {
    "dev": "nodemon --exec node --loader ts-node/esm src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node scripts/install-gitleaks.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "p-limit": "^6.1.0",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "msw": "^2.0.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "tree-sitter": "^0.22.0",
    "tree-sitter-go": "^0.23.0",
    "tree-sitter-java": "^0.23.0",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-python": "^0.23.0",
    "tree-sitter-ruby": "^0.23.0",
    "tree-sitter-typescript": "^0.23.0"
  },
  "keywords": [
    "security",
    "mcp",
    "claude-code",
    "penetration-testing"
  ],
  "license": "MIT"
}
